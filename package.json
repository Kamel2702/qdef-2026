{
  "name": "qdef-conference",
  "version": "1.0.0",
  "description": "Q-DEF Conference Luxembourg - Event Website",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node index.js",
