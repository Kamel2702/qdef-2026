{
  "name": "qdef-conference",
  "version": "1.0.0",
  "description": "Q-DEF Conference Luxembourg - Event Website",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "seed": "cd server && node seed.js",
    "start": "cd server && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "serverless-http": "^4.0.0",
    "sql.js": "^1.14.1"
  }
}
